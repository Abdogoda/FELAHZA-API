{
  "openapi": "3.0.3",
  "info": {
    "title": "Fi Lahza API",
    "description": "API Documentation for Felahza (Fi Lahza) Backend. Fully compatible with Apidog. Supports Provider and Driver authentication, profile retrieval, and document upload endpoints.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/v1",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/provider/register": {
      "post": {
        "tags": ["Provider Auth"],
        "summary": "Register Provider",
        "description": "Create a new provider account in the system.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterProviderRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Provider registered successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "provider": {
                      "$ref": "#/components/schemas/Provider"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation errors."
          }
        }
      }
    },
    "/provider/login": {
      "post": {
        "tags": ["Provider Auth"],
        "summary": "Login Provider",
        "description": "Authenticate provider and get a Sanctum access token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "token": {
                      "type": "string"
                    },
                    "provider": {
                      "$ref": "#/components/schemas/Provider"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials."
          },
          "403": {
            "description": "Deactivated or pending account verification.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "deactivation_reason": {
                      "type": "string"
                    },
                    "token": {
                      "type": "string"
                    },
                    "provider": {
                      "$ref": "#/components/schemas/Provider"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/provider/forgot-password": {
      "post": {
        "tags": ["Provider Auth"],
        "summary": "Provider Forgot Password",
        "description": "Send a password reset link to the provider's email.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset email sent."
          },
          "422": {
            "description": "Invalid email."
          }
        }
      }
    },
    "/provider/reset-password": {
      "post": {
        "tags": ["Provider Auth"],
        "summary": "Provider Reset Password",
        "description": "Reset provider password using token received in email.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successful."
          },
          "422": {
            "description": "Invalid token or passwords match error."
          }
        }
      }
    },
    "/provider/logout": {
      "post": {
        "tags": ["Provider Auth"],
        "summary": "Logout Provider",
        "description": "Revoke active Sanctum token.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logged out successfully."
          },
          "401": {
            "description": "Unauthenticated."
          }
        }
      }
    },
    "/provider/profile": {
      "get": {
        "tags": ["Provider Profile"],
        "summary": "Get Provider Profile",
        "description": "Retrieve active authenticated provider profile info.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Provider profile retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Provider"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated."
          }
        }
      }
    },
    "/provider/documents": {
      "post": {
        "tags": ["Provider Profile"],
        "summary": "Upload Document",
        "description": "Upload provider document (ID, Tax record, License).",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadDocumentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document uploaded successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "document": {
                      "$ref": "#/components/schemas/Document"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation errors."
          }
        }
      }
    },
    "/driver/register": {
      "post": {
        "tags": ["Driver Auth"],
        "summary": "Register Driver",
        "description": "Create a new driver account in the system.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterDriverRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Driver registered successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "driver": {
                      "$ref": "#/components/schemas/Driver"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation errors."
          }
        }
      }
    },
    "/driver/login": {
      "post": {
        "tags": ["Driver Auth"],
        "summary": "Login Driver",
        "description": "Authenticate driver and get a Sanctum access token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "token": {
                      "type": "string"
                    },
                    "driver": {
                      "$ref": "#/components/schemas/Driver"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials."
          },
          "403": {
            "description": "Deactivated or pending account verification.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "deactivation_reason": {
                      "type": "string"
                    },
                    "token": {
                      "type": "string"
                    },
                    "driver": {
                      "$ref": "#/components/schemas/Driver"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/driver/forgot-password": {
      "post": {
        "tags": ["Driver Auth"],
        "summary": "Driver Forgot Password",
        "description": "Send a password reset link to the driver's email.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset email sent."
          },
          "422": {
            "description": "Invalid email."
          }
        }
      }
    },
    "/driver/reset-password": {
      "post": {
        "tags": ["Driver Auth"],
        "summary": "Driver Reset Password",
        "description": "Reset driver password using token received in email.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password reset successful."
          },
          "422": {
            "description": "Invalid token or passwords match error."
          }
        }
      }
    },
    "/driver/logout": {
      "post": {
        "tags": ["Driver Auth"],
        "summary": "Logout Driver",
        "description": "Revoke active Sanctum token.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logged out successfully."
          },
          "401": {
            "description": "Unauthenticated."
          }
        }
      }
    },
    "/driver/profile": {
      "get": {
        "tags": ["Driver Profile"],
        "summary": "Get Driver Profile",
        "description": "Retrieve active authenticated driver profile info.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Driver profile retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Driver"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated."
          }
        }
      }
    },
    "/driver/documents": {
      "post": {
        "tags": ["Driver Profile"],
        "summary": "Upload Document",
        "description": "Upload driver document (ID, License).",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UploadDocumentRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document uploaded successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "document": {
                      "$ref": "#/components/schemas/Document"
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation errors."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Provide access token received upon successful login."
      }
    },
    "schemas": {
      "RegisterProviderRequest": {
        "type": "object",
        "required": ["full_name", "business_name", "email", "phone", "password", "password_confirmation"],
        "properties": {
          "full_name": {
            "type": "string",
            "maxLength": 150
          },
          "business_name": {
            "type": "string",
            "maxLength": 150
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 150
          },
          "phone": {
            "type": "string",
            "maxLength": 20
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "password_confirmation": {
            "type": "string"
          }
        }
      },
      "RegisterDriverRequest": {
        "type": "object",
        "required": ["full_name", "email", "phone", "password", "password_confirmation"],
        "properties": {
          "full_name": {
            "type": "string",
            "maxLength": 150
          },
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 150
          },
          "phone": {
            "type": "string",
            "maxLength": 20
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "password_confirmation": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "phone": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ResetPasswordRequest": {
        "type": "object",
        "required": ["token", "email", "password", "password_confirmation"],
        "properties": {
          "token": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "password_confirmation": {
            "type": "string"
          }
        }
      },
      "UploadDocumentRequest": {
        "type": "object",
        "required": ["doc_type", "file"],
        "properties": {
          "doc_type": {
            "type": "string",
            "enum": ["national_id", "tax_card", "commercial_register", "driver_license", "vehicle_registration"]
          },
          "file": {
            "type": "string",
            "format": "binary"
          }
        }
      },
      "Provider": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "full_name": {
            "type": "string"
          },
          "business_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "business_address": {
            "type": "string",
            "nullable": true
          },
          "gps_lat": {
            "type": "number",
            "nullable": true
          },
          "gps_lng": {
            "type": "number",
            "nullable": true
          },
          "wallet_balance": {
            "type": "number"
          },
          "language": {
            "type": "string"
          },
          "verification_status": {
            "type": "string",
            "enum": ["pending", "approved", "rejected"]
          },
          "account_status": {
            "type": "string",
            "enum": ["active", "deactivated"]
          },
          "deactivation_reason": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Driver": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "full_name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "gps_lat": {
            "type": "number",
            "nullable": true
          },
          "gps_lng": {
            "type": "number",
            "nullable": true
          },
          "wallet_balance": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": ["online", "offline", "busy"]
          },
          "rating": {
            "type": "number"
          },
          "total_trips": {
            "type": "integer"
          },
          "language": {
            "type": "string"
          },
          "verification_status": {
            "type": "string",
            "enum": ["pending", "approved", "rejected"]
          },
          "account_status": {
            "type": "string",
            "enum": ["active", "deactivated"]
          },
          "deactivation_reason": {
            "type": "string",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "user_id": {
            "type": "integer"
          },
          "user_type": {
            "type": "string"
          },
          "doc_type": {
            "type": "string"
          },
          "file_url": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
